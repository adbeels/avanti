# Variables que Vite expone al frontend (deben empezar con VITE_).
# Copia este archivo a .env (que está en .gitignore) y rellena los valores
# reales. En AWS Amplify estas mismas variables se configuran en
# App settings → Environment variables.

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica-de-supabase
