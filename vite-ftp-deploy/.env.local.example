# Credenciales FTP del proyecto. NO lo comitees a git.
# El asistente de instalación ya añadió `.env.local` y `*.local` al .gitignore.

DEPLOY_FTP_HOST=ftp.tudominio.com
DEPLOY_FTP_PORT=21
DEPLOY_FTP_USER=usuario@tudominio.com
DEPLOY_FTP_PASSWORD="contraseña-entre-comillas-si-tiene-#-o-caracteres-especiales"
DEPLOY_FTP_SECURE=false
DEPLOY_FTP_REMOTE_DIR=public_html/subdominio

# Opcional: URL pública del sitio para mostrar al final del deploy
DEPLOY_SITE_URL=https://subdominio.tudominio.com
